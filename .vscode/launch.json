{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch API",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/MainSolutions.API/MainSolutions.API.csproj",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000"
      }
    },
    {
      "name": "Launch React",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "cwd": "${workspaceFolder}/MainSolutions.React",
      "env": {
        "PORT": "3000",
        "BROWSER": "none",
        "REACT_APP_API_URL": "https://localhost:5001"
      }
    }
  ],
  "compounds": [
    {
      "name": "Launch API + React",
      "configurations": ["Launch API", "Launch React"],
      "stopAll": true
    }
  ]
}